{
  "name": "art-timecode-gen",
  "version": "0.0.17",
  "author": "Marece Williams",
  "description": "ArtNet Timecode Generator",
  "homepage": "./",
  "main": ".vite/build/main.js",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "nanotimer": "^0.3.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "scripts": {
    "dev": "electron-forge start",
    "build": "vite build",
    "test": "echo \"No tests configured\" && exit 0",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "deploy": "electron-forge make --publish always",
    "backup": "git add . && git commit -m %NPM_PACKAGE_VERSION% && git push origin main",
    "upload": "pnpm build && pnpm backup && pnpm deploy",
    "mac": "pnpm && pnpm build && pnpm deploy",
    "try": "pnpm build && pnpm package",
    "refresh": "pnpm upgrade --latest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wbmmusic/art-timecode-gen.git"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.1",
    "@electron-forge/maker-deb": "7.11.1",
    "@electron-forge/maker-dmg": "7.11.1",
    "@electron-forge/maker-rpm": "7.11.1",
    "@electron-forge/maker-squirrel": "7.11.1",
    "@electron-forge/maker-zip": "7.11.1",
    "@electron-forge/plugin-vite": "7.11.1",
    "@electron-forge/publisher-github": "7.11.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "typescript": "^6.0.2",
    "vite": "8.0.8"
  },
  "packageManager": "pnpm@9.2.0+sha512.98a80fd11c2e7096747762304106432b3ddc67dcf54b5a8c01c93f68a2cd5e05e6821849522a06fb76284d41a2660d5e334f2ee3bbf29183bf2e739b1dafa771"
}
